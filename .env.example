# Amadeus API Credentials
# Get them from https://developers.amadeus.com/my-apps
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# Google Places API Key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional: Node Environment
NODE_ENV=development

# Database (Neon)
# Local development should point to the develop branch URL.
DATABASE_URL=postgresql://<db_user>:<db_password>@<develop-branch-host>/neondb?sslmode=require&channel_binding=require

#dev:
DATABASE_URL='postgresql://neondb_owner:npg_wCO4UTB7Ylds@ep-lively-water-a9qduulf-pooler.gwc.azure.neon.tech/neondb?sslmode=require&channel_binding=require'
#stage:

#prod:
DATABASE_URL=postgresql://neondb_owner:npg_wCO4UTB7Ylds@ep-twilight-rain-a9e8ehdk-pooler.gwc.azure.neon.tech/neondb?sslmode=require&channel_binding=require


# Deployment env examples (set these in your hosting provider, not in git):
# DATABASE_URL_STAGE=postgresql://<db_user>:<db_password>@<stage-branch-host>/neondb?sslmode=require&channel_binding=require
# DATABASE_URL_PRODUCTION=postgresql://<db_user>:<db_password>@<production-branch-host>/neondb?sslmode=require&channel_binding=require

# JWT Secret (use a random 32+ character string, never commit the real value)
JWT_SECRET=your-random-32-char-secret-here

# Gmail SMTP (for email verification)
# Use an App Password, NOT your Google account password.
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Icon Fly <your-gmail@gmail.com>"

# Base URL (used to build verification links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
