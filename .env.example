# Amadeus API Credentials
# Get them from https://developers.amadeus.com/my-apps
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# Google Places API Key
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional: Node Environment
NODE_ENV=development

# Authentication & Email Verification
# SMTP Config for sending verification emails (e.g., Gmail App Password)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
# JWT secret for signing session cookies
JWT_SECRET=your_random_secret_string
# App URL for email verification links (default: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
